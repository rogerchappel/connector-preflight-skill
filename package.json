{
  "name": "connector-preflight-skill",
  "version": "0.1.0",
  "description": "Local-first agent skill for checking connector action readiness before side effects.",
  "type": "module",
  "bin": {
    "connector-preflight": "./bin/connector-preflight.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check bin/connector-preflight.js && node --check src/index.js",
    "smoke": "node bin/connector-preflight.js check fixtures/connectors.json fixtures/action.needs-approval.json --format markdown",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent",
    "skill",
    "connector",
    "preflight",
    "dry-run"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/connector-preflight-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/connector-preflight-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/connector-preflight-skill#readme"
}
